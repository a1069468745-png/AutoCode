COMPOSE_PROJECT_NAME=autocode
SPRING_PROFILES_ACTIVE=local
WEB_CONSOLE_PORT=18088

POSTGRES_IMAGE=postgres:16
POSTGRES_DB=autocode
POSTGRES_USER=autocode
POSTGRES_PASSWORD=replace_me
POSTGRES_HOST_PORT=5432

REDIS_IMAGE=redis:7.2-alpine
REDIS_PASSWORD=replace_me
REDIS_HOST_PORT=6379

QDRANT_IMAGE=qdrant/qdrant:latest
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

NGINX_IMAGE=nginx:1.27-alpine
NGINX_HOST_PORT=8080

API_GATEWAY_PORT=18080
PROJECT_SERVICE_PORT=18081
CONTEXT_SERVICE_PORT=18082
CODEGRAPH_RUNNER_PORT=18083
HISTORY_INDEXER_PORT=18084
KNOWLEDGE_INDEXER_PORT=18085
LLM_GATEWAY_PORT=18086
DEV_AGENT_SERVICE_PORT=18087

ROOT_LOG_LEVEL=INFO
APP_LOG_LEVEL=INFO
WORKSPACE_ROOT=./workspace
DOCS_ROOT=./docs

LLM_PROVIDER=openai-compatible
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=replace_me
LLM_MODEL_NAME=gpt-4o-mini
LLM_FALLBACK_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30
LLM_ENABLE_LOCAL_ONLY=false
